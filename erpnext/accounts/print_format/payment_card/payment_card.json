 "html": "<table width=\"100%\">\n    <tr>\n        <td width=\"65%\">\n            {{ frappe.db.get_value(\"Letter Head\", {\"name\": \"KOP HKP\"}, [\"content\"]) }}\n        </td>\n        <td width=\"35%\" style=\"padding-right: 2px !important;\">\n            <table style=\"font-size: 10px; border:1px solid black; margin: 0px; padding: 0px;\" class=\"ml-auto\">\n                <tr>\n                    <td style=\"padding: 2px !important;\">Dokumen</td>\n                    <td style=\"padding: 2px !important;\">: -</td>\n                </tr>\n                \n                <tr>\n                    <td style=\"padding: 2px !important;\">Revisi</td>\n                    <td style=\"padding: 2px !important;\">: 00</td>\n                </tr>\n                \n                <tr>\n                    <td style=\"padding: 2px !important;\">Tgl.Terbit</td>\n                    <td style=\"padding: 2px !important;\">: -</td>\n                </tr>\n            </table>\n        </td>\n    </tr>\n</table>\n\n<div class=\"text-center\">\n    <h4>KARTU HUTANG</h4>\n</div>\n\n<div class=\"row\">\n    <div class=\"col-md-12\">\n        <table style=\"font-size: 10px !important; width: 100%; font-family: Arial\">\n            <tbody>\n                <tr>\n                    <td width=\"6%\"><b>NAMA</b></td>\n                    <td width=\"54%\">: {{doc.vendor_name or \"\"}}</td>\n                    <td width=\"6%\"><b>ALAMAT</b></td>\n                    <td width=\"34%\">: {{doc.address or \"\"}}</td>\n                </tr>\n                <tr>\n                    <td><b>TYPE</b></td>\n                    <td>: {% if doc.vendor_type == \"Sub Contract\" %}SUB KONTRAKTOR{% else %}SUPPLIER{% endif %}</td>\n                    <td><b>PROYEK</b></td>\n                    <td>: {{doc.project_name or \"\"}}</td>\n                </tr>\n                \n                <tr>\n                    <td><b>{% if doc.type == \"Sub Contract Hand Over\" %}SPK{% else %}SPB{% endif %}</b></td>\n                    <td>: {{doc.document or \"\"}}</td>\n                    <td rowspan=\"3\" colspan=\"2\">\n                        <b>NILAI KONTRAK</b><br>\n                        <table width=\"100%\" style=\"font-size: 9px !important; width: 100%; font-family: Arial;\">\n                            <tr class=\"bg-dark\">\n                                <td class=\"text-center\" style=\"border: 1px solid black\"><b>TANGGAL</b></td>\n                                <td class=\"text-center\" style=\"border: 1px solid black\"><b>BERLAKU SAMPAI</b></td>\n                                <td class=\"text-center\" style=\"border: 1px solid black\"><b>AMANDEMEN</b></td>\n                                <td class=\"text-center\" style=\"border: 1px solid black\"><b>NILAI KONTRAK</b></td>\n                            </tr>\n                            <tr>\n                                <td class=\"text-center\" style=\"border: 1px solid black\">{{ doc.get_formatted(\"contract_date\") }}</td>\n                                <td class=\"text-center\" style=\"border: 1px solid black\">{{ doc.get_formatted(\"contract_due_date\") }}</td>\n                                <td class=\"text-right\" style=\"border: 1px solid black\">{{ doc.get_formatted(\"amandement\") }}</td>\n                                <td class=\"text-right\" style=\"border: 1px solid black\">{{ doc.get_formatted(\"contract_value\") }}</td>\n                            </tr>\n                        </table>\n                    </td>\n                </tr>\n                \n                <tr>\n                    <td><b>PEKERJAAN</b></td>\n                    <td>: {{doc.job_name or \"\"}}</td>\n                </tr>\n                <tr>\n                    <td><b>KETERANGAN</b></td>\n                    <td>: {{doc.description or \"\"}}</td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n</div>\n\n<!-- Peserta Tender -->\n<table style=\"font-size: 10px; width: 100%; font-family: Arial\">\n    <thead>\n        <tr style=\"border: 1px solid black\">\n            <th class=\"text-center\" style=\"border: 1px solid black\">NO</th>\n            <th class=\"text-center\" style=\"border: 1px solid black\">TANGGAL</th>\n            <th class=\"text-center\" style=\"border: 1px solid black\">URAIAN</th>\n            <th class=\"text-center\" style=\"border: 1px solid black\">PROGRESS PHISIK</th>\n            <th class=\"text-center\" style=\"border: 1px solid black\">PEMBAYARAN</th>\n            <th class=\"text-center\" style=\"border: 1px solid black\">TOTAL PEMBAYARAN</th>\n            <th class=\"text-center\" style=\"border: 1px solid black\">SALDO</th>\n            <th class=\"text-center\" style=\"border: 1px solid black\">KETERANGAN</th>\n        </tr>\n    </thead>\n    <tbody>\n        {%- set it = namespace(total_payment=0) -%}\n        {%- for det in doc.detail -%}\n        <tr style=\"border: 1px solid black\">\n            <td style=\"border: 1px solid black\">{{ loop.index }}</td>\n            <td style=\"border: 1px solid black\">{{ det.get_formatted(\"date\") }}</td>\n            <td style=\"border: 1px solid black\">{{ det.uraian or \"\"}}</td>\n            <td style=\"border: 1px solid black; text-align: right;\">{{det.get_formatted(\"progress\") or \"0\"}}</td>\n            <td style=\"border: 1px solid black; text-align: right;\">{{det.get_formatted(\"payment\") or \"0\"}}</td>\n            <td style=\"border: 1px solid black; text-align: right;\">{{det.get_formatted(\"total_payment\") or \"\"}}</td>\n            <td style=\"border: 1px solid black; text-align: right;\">{{det.get_formatted(\"saldo\") or \"\"}}</td>\n            <td style=\"border: 1px solid black\">{{ det.keterangan or \"\"}}</td>\n            {% set it.total_payment = it.total_payment+det.payment %}\n        </tr>\n        {%- endfor -%}\n    </tbody>\n    <tfoot>\n        <tr style=\"border: 1px solid black\">\n            <th class=\"text-center\" style=\"border: 1px solid black\" colspan=\"4\">TOTAL</th>\n            <th class=\"text-center\" style=\"border: 1px solid black; text-align: right;\">{{\"{:,.0f}\".format(it.total_payment)|replace(\",\", \"-\")|replace(\".\", \",\")|replace(\"-\", \".\") }}</th>\n            \n        </tr>\n    </tfoot>\n</table>",
